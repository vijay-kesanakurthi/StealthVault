# Ethereum Sepolia + Fhenix CoFHE (keeper)
# Copy to .env and fill in.
# CommonJS only: `cofhejs` breaks under ESM ("Dynamic require of stream").

# Sepolia JSON-RPC (or use SEPOLIA_RPC_URL; root .env often defines that)
RPC_URL=https://ethereum-sepolia.publicnode.com

PRIVATE_KEY=0x...

# After: npm run deploy:sepolia  (from repo root, with PRIVATE_KEY + SEPOLIA_RPC_URL in root .env)
CONTRACT_ADDRESS=0x...

# Fhenix CoFHE testnet (default). Use MOCK/LOCAL only for Hardhat mocks — not for Sepolia.
FHE_ENV=TESTNET

# How often to scan for StrategyEvaluated (HTTP RPCs cannot rely on eth_newFilter).
# POLL_INTERVAL_MS=12000
