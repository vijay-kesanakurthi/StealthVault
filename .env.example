# Wallet (never commit a real key). Required for Sepolia deploy and keeper.
PRIVATE_KEY=your_wallet_private_key_here

# RPC URLs
RPC_URL=http://127.0.0.1:8545
# Used by Hardhat --network eth-sepolia and optional keeper fallback
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Deploy StrategyRegistry to Ethereum Sepolia (Fhenix CoFHE):
#   npm run deploy:sepolia

# Optional: Etherscan/Arbiscan for contract verification
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=

# Optional: Gas reporter (npm run test:gas)
REPORT_GAS=true
COINMARKETCAP_API_KEY=
