# Deployed StrategyRegistry on Sepolia
VITE_CONTRACT_ADDRESS=0xYourContractAddress

# Optional: chain id for localStorage namespacing (default 11155111 Sepolia). Must match the network you use.
# VITE_CHAIN_ID=11155111

# Optional: custom Sepolia RPC (defaults to public node)
# VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com

# Optional: merge older wallet→contract txs (Etherscan API V2 — one key for all chains)
# https://docs.etherscan.io/v2-migration
# VITE_ETHERSCAN_API_KEY=
# Optional: override V2 API URL (default https://api.etherscan.io/v2/api)
# VITE_ETHERSCAN_API_BASE=
# Optional: chain id for V2 chainid= (default 11155111 Sepolia)
# VITE_ETHERSCAN_CHAIN_ID=
